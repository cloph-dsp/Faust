# ===========================================
# VST3 Plugin Development Workspace Gitignore
# ===========================================

# -------------------------------------------
# Node.js / Bun (npm packages)
# -------------------------------------------
node_modules/

# -------------------------------------------
# Build Outputs & Compiled Binaries
# -------------------------------------------
*.vst3/
*.vst/
*.component/
*.app/
build-win/
build-mac/
build/
Build/
*.dll
*.dylib
*.so
*.exe
*.bin

# -------------------------------------------
# IDE & Project Files (keep local configs)
# -------------------------------------------
*.dsw
*.sln
*.vcxproj
*.vcxproj.filters
*.vcxproj.user
# Grungr project files (required for CI build)
!Grungr/projects/*.vcxproj
!Grungr/projects/*.vcxproj.filters
# BronzeNoise project files (required for CI build, same reason as Grungr)
!BronzeNoise/projects/*.vcxproj
!BronzeNoise/projects/*.vcxproj.filters
# 3BeatProblem project files (required for CI build)
!3BeatProblem/projects/*.vcxproj
!3BeatProblem/projects/*.vcxproj.filters
# Dead failed attempt directories (not source, just references)
3BeatProblem/failed attempt*/
*.suo
*.userosscache
*.sln.docstates
*.ncb
*.opensdf
*.sdf
*.cachefile
*.VC.db
*.VC.VC.opendb
*.vcxcheck
*.jucer
.jucer~
*~
CMakeLists.txt.user

# JetBrains
.idea/
*.iml

# Eclipse
.classpath
.project
.settings/

# -------------------------------------------
# iPlug2 & VST3 SDK (submodules - keep local copies)
# -------------------------------------------
iPlug2/
vst3sdk/

# -------------------------------------------
# Backup & Temporary Files
# -------------------------------------------
backups/
backup/
*.bak
*.tmp
*.temp

# -------------------------------------------
# OS-Specific Files
# -------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
*.stackdump
*.lnk
.AppleDouble
.LSOverride
Icon
._*
*.lsb

# -------------------------------------------
# Logs & Debug Files
# -------------------------------------------
*.log
logs/
*.crash

# -------------------------------------------
# Compiler Cache Files
# -------------------------------------------
*.pch
*.ilk
*.exp
*.lib
*.idb
*.pdb
*.iobj

# -------------------------------------------
# Old Project Files
# -------------------------------------------
OLD/
old/
References/
#references/

# -------------------------------------------
# Third-Party Libraries (if not using submodules)
# -------------------------------------------
external/
External/
3rdparty/
3rd_party/
vendor/
.agents/

# -------------------------------------------
# Generated DSP code (Faust output)
# -------------------------------------------
*_gen.h
*_gen.cpp
*_gen.dsp

# Tuner VST's Faust-generated DSP header is committed because the CI
# workflow copies it into the iPlug2 example tree but doesn't run the
# Faust compiler.  Keeping it tracked avoids a "faust(1) not found" CI
# failure without buying a cross-platform faust install step.
!Tuner VST/TunerDSP_gen.h

# -------------------------------------------
# Python Virtual Environments
# -------------------------------------------
.venv/
venv/
__pycache__/
*.pyc
*.pyo
.env

# Ignore reserved device filename on Windows that can break git
nul
