# ===========================================
# VST3 Plugin Development Workspace Gitignore
# ===========================================

# -------------------------------------------
# Build Outputs & Compiled Binaries
# -------------------------------------------
*.vst3/
*.vst/
*.component/
*.app/
build-win/
build-mac/
build/
Build/
*.dll
*.dylib
*.so
*.exe
*.bin

# -------------------------------------------
# IDE & Project Files (keep local configs)
# -------------------------------------------
*.dsw
*.sln
*.vcxproj
*.vcxproj.filters
*.vcxproj.user
*.suo
*.userosscache
*.sln.docstates
*.ncb
*.opensdf
*.sdf
*.cachefile
*.VC.db
*.VC.VC.opendb
*.vcxcheck
*.jucer
.jucer~
*~
CMakeLists.txt.user

# JetBrains
.idea/
*.iml

# Eclipse
.classpath
.project
.settings/

# -------------------------------------------
# iPlug2 & VST3 SDK (submodules - keep local copies)
# -------------------------------------------
iPlug2/
vst3sdk/

# -------------------------------------------
# Backup & Temporary Files
# -------------------------------------------
backups/
backup/
*.bak
*.tmp
*.temp

# -------------------------------------------
# OS-Specific Files
# -------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
*.stackdump
*.lnk
.AppleDouble
.LSOverride
Icon
._*
*.lsb

# -------------------------------------------
# Logs & Debug Files
# -------------------------------------------
*.log
logs/
*.crash

# -------------------------------------------
# Compiler Cache Files
# -------------------------------------------
*.pch
*.ilk
*.exp
*.lib
*.idb
*.pdb
*.iobj

# -------------------------------------------
# Old Project Files
# -------------------------------------------
OLD/
old/
References/
#references/

# -------------------------------------------
# Third-Party Libraries (if not using submodules)
# -------------------------------------------
external/
External/
3rdparty/
3rd_party/
vendor/
.agents/

# -------------------------------------------
# Python Virtual Environments
# -------------------------------------------
.venv/
venv/
__pycache__/
*.pyc
*.pyo
.env

